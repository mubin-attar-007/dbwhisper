# Server-side proxy target. Next.js rewrites /api/* to this origin (no CORS needed).
#   Local dev: your running backend (uvicorn on :8000).
#   Vercel:    set to the deployed API origin, e.g. https://heisenbergblue-dbwhisper.hf.space
API_PROXY_TARGET=http://localhost:8000

# Optional: override the client-side base path (defaults to /api, which is proxied above).
# Set this only to bypass the proxy and call the backend directly (requires backend CORS).
# NEXT_PUBLIC_API_BASE=/api

# Sentry error tracking (optional; no-op when unset). Client + server DSN.
NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_DSN=   # defaults to NEXT_PUBLIC_SENTRY_DSN for the server runtime

# Show the login/signup UI. Set to "true" together with the backend USER_AUTH_ENABLED.
NEXT_PUBLIC_AUTH_ENABLED=
