# ─────────────────────────────────────────────────────────────────────────────
# DBWhisper — environment template. Copy to `.env` and fill in. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# ─── LLM PROVIDERS ───────────────────────────────────────────────────────────
# At least one is required. The agent tries providers in priority order
# (see PROVIDER_PRIORITY in app/agent/chain.py) and falls back on rate limits.
# Google Gemini (free tier) powers BOTH chat and the default embedding provider.
# GEMINI_API_KEY is automatically aliased to GOOGLE_API_KEY at startup.
GEMINI_API_KEY=
# Groq (free, fast):
GROQ_API_KEY=
# Optional additional providers:
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# DEEPSEEK_API_KEY=
# ANTHROPIC_API_KEY=

# ─── PROJECT DATABASE (Postgres + pgvector) ──────────────────────────────────
# Stores conversation memory and schema embeddings. Requires the `vector` extension.
#   Local:  postgresql+psycopg://USER:PASSWORD@localhost:5432/DBNAME
#   Neon:   postgresql+psycopg://USER:PASSWORD@HOST/DBNAME?sslmode=require
POSTGRES_CONNECTION_STRING=

# ─── EMBEDDINGS ──────────────────────────────────────────────────────────────
# "google" = hosted, lean, no torch (default — recommended for deploys).
# "huggingface" = local/offline; requires `uv sync --extra local-embeddings` (pulls torch).
# NOTE: vectors are provider/model-specific. If you change provider or model you must
#       re-enroll/re-embed schemas (existing vectors become dimensionally incompatible).
EMBEDDING_PROVIDER=google
# GOOGLE_EMBEDDING_MODEL=models/text-embedding-004
# EMBEDDING_MODEL_NAME=jinaai/jina-embeddings-v3   # used only when provider=huggingface

# ─── SERVER ──────────────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8000
# development | production  (production logs a warning if CORS is left wide-open)
APP_ENV=development

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins. "*" is fine for local dev; in production set this
# to your exact frontend origin(s), e.g. https://dbwhisper.vercel.app
CORS_ALLOW_ORIGINS=*
